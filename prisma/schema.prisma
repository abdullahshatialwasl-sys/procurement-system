generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Request {
  id            Int     @id @default(autoincrement())
  companyName   String
  requestType   String
  priority      String  @default("عادي")
  referenceNo   String?
  details       String?
  applicantName String
  phone         String
  fileUrl       String?
  status        String  @default("جديد")

  reply        String?
  replyFileUrl String?
  replyAt      DateTime?

  replies RequestReply[]

  attachments RequestAttachment[]

  createdAt DateTime @default(now())
}

model RequestReply {
  id        Int @id @default(autoincrement())
  requestId Int

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  reply     String?
  fileUrl   String?
  createdAt DateTime @default(now())
}

model RequestAttachment {
  id        Int @id @default(autoincrement())
  requestId Int

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
}